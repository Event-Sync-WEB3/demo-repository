generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LinkPlatform {
  twitter
  linkedin
  github
  youtube
  website
  other
}

model Organizer {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events Event[]
}

model Event {
  id          String   @id @default(uuid())
  organizerId String
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer Organizer @relation(fields: [organizerId], references: [id])
  rooms     Room[]
  speakers  Speaker[]
  sessions  Session[]
}

model Room {
  id      String @id @default(uuid())
  eventId String
  name    String

  event    Event     @relation(fields: [eventId], references: [id])
  sessions Session[]

  @@unique([eventId, name])
}

model Speaker {
  id         String   @id @default(uuid())
  eventId    String
  fullName   String
  bio        String?
  photoUrl   String?
  slug       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event   Event          @relation(fields: [eventId], references: [id])
  links   SpeakerLink[]
  sessions SessionSpeaker[]

  @@unique([eventId, slug])
}

model SpeakerLink {
  id        String       @id @default(uuid())
  speakerId String
  platform  LinkPlatform
  label     String?
  url       String
  sortOrder Int @default(0)

  speaker Speaker @relation(fields: [speakerId], references: [id])
}

model Session {
  id          String   @id @default(uuid())
  eventId     String
  roomId      String?
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event    Event     @relation(fields: [eventId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])
  speakers SessionSpeaker[]
  questions Question[]
}

model SessionSpeaker {
  sessionId String
  speakerId String
  sortOrder Int @default(0)

  session Session @relation(fields: [sessionId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@id([sessionId, speakerId])
}

model Question {
  id         String   @id @default(uuid())
  sessionId  String
  content    String
  authorName String?
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
}